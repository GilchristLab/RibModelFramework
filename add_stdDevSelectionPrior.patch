--- a/src/MCMCAlgorithm.cpp
+++ b/src/MCMCAlgorithm.cpp
@@ -30,6 +30,7 @@ void MCMCAlgorithm::updateParameters() {
     double newStdDevSynthesisRate = proposeNewStdDev(stdDevSynthesisPrior[currentCategory]);
     stdDevSynthesisPrior[currentCategory] = newStdDevSynthesisRate;
+
+    double newStdDevSelectionPrior = proposeNewStdDev(stdDevSelectionPrior[currentCategory]);
+    stdDevSelectionPrior[currentCategory] = newStdDevSelectionPrior;
 }

