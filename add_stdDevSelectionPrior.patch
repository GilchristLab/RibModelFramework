diff --git a/src/include/base/Parameter.h b/src/include/base/Parameter.h
index 49af56b..94c0488 100755
--- a/src/include/base/Parameter.h
+++ b/src/include/base/Parameter.h
@@ -20,6 +20,7 @@ class Parameter {
 private:
     std::vector<double> stdDevSynthesisPrior;
+    std::vector<double> stdDevSelectionPrior;
 public:
     Parameter();
     double getStdDevSynthesisRate(unsigned category) const;
+    double getStdDevSelectionPrior(unsigned category) const;
     void setStdDevSynthesisRate(unsigned category, double value);
+    void setStdDevSelectionPrior(unsigned category, double value);
     void writeParameterToFile(std::ostream& out);
     void readParameterFromFile(std::istream& in);
 };

diff --git a/src/Parameter.cpp b/src/Parameter.cpp
index 49af56b..94c0488 100755
--- a/src/Parameter.cpp
+++ b/src/Parameter.cpp
@@ -10,6 +10,7 @@ Parameter::Parameter() {
     stdDevSynthesisPrior.resize(1, 1.0);
+    stdDevSelectionPrior.resize(1, 1.0);
 }

+double Parameter::getStdDevSelectionPrior(unsigned category) const {
+    return stdDevSelectionPrior.at(category);
+}
+void Parameter::setStdDevSelectionPrior(unsigned category, double value) {
+    stdDevSelectionPrior.at(category) = value;
+}

 void Parameter::writeParameterToFile(std::ostream& out) {
     for (double value : stdDevSynthesisPrior) out << value << " ";
+    for (double value : stdDevSelectionPrior) out << value << " ";
 }

 void Parameter::readParameterFromFile(std::istream& in) {
     for (double &value : stdDevSynthesisPrior) in >> value;
+    for (double &value : stdDevSelectionPrior) in >> value;
 }

diff --git a/src/MCMCAlgorithm.cpp b/src/MCMCAlgorithm.cpp
